                "type": "text/javascript",
                "exec": [
                  "pm.test('Health is public', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Health response shape is valid', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('status', 'ok');",
                  "  pm.expect(json).to.have.property('application');",
                  "  pm.expect(json).to.have.property('timestamp');",
