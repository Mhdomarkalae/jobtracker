  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const requestName = pm.info.requestName;",
          "const tokenVar = pm.variables.get('token_var');",
          "if (tokenVar) {",
          "  const token = pm.environment.get(tokenVar);",
          "  if (token) {",
          "    pm.environment.set('active_token', token);",
          "  }",
          "}",
          "",
          "if (requestName === 'Signup User A') {",
          "  const stamp = Date.now();",
          "  pm.environment.set('audit_stamp', String(stamp));",
          "  pm.environment.set('user_a_email', `postman.usera.${stamp}@example.com`);",
          "  pm.environment.set('user_b_email', `postman.userb.${stamp}@example.com`);",
          "}",
          "",
          "if (!pm.environment.get('user_a_password')) {",
          "  pm.environment.set('user_a_password', 'password123');",
          "}",
          "if (!pm.environment.get('user_b_password')) {",
          "  pm.environment.set('user_b_password', 'password123');",
          "}"
        ]
      }
    }
  ],
